# ═══════════════════════════════════════════════════════
# EMBEDDINGS
# ═══════════════════════════════════════════════════════
EMBEDDINGS_BASE_URL=http://localhost:11434/v1
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_API_KEY=ollama

# ═══════════════════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════════════════
DATABASE_URL=postgresql://cecilia:cecilia_2026@postgres:5432/cecilia_db
REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════
# SEGURIDAD
# ═══════════════════════════════════════════════════════
JWT_SECRET=cambiar-en-produccion-generar-con-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ═══════════════════════════════════════════════════════
# APLICACIÓN
# ═══════════════════════════════════════════════════════
APP_NAME=CecilIA v2
APP_VERSION=2.0.0
DOMAIN=localhost
ENVIRONMENT=development

# ═══════════════════════════════════════════════════════
