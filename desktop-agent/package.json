{
  "name": "cecilia-desktop-agent",
  "version": "2.0.0",
  "description": "Agente de escritorio CecilIA v2 — Integración local con el sistema de IA para control fiscal de la CGR Colombia",
  "main": "src/main.js",
  "author": {
    "name": "Equipo Técnico CecilIA — CD-TIC-CGR",
    "email": "sistemas@contraloria.gov.co"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "lint": "eslint src/",
    "test": "jest"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "chokidar": "^3.6.0",
    "ws": "^8.17.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "co.gov.contraloria.cecilia.agent",
    "productName": "CecilIA Agent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["es_ES"]
    }
  }
}
