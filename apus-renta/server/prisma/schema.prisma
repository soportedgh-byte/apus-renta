// ============================================================
// APUS Renta - Prisma Schema
// Multi-tenant property rental management system
// Provider: MySQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  PROPIETARIO
  ARRENDATARIO
  ENCARGADO
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PropertyType {
  CASA
  APARTAMENTO
  LOCAL
  OFICINA
  BODEGA
}

enum PropertyStatus {
  DISPONIBLE
  OCUPADO
  MANTENIMIENTO
}

enum DocumentType {
  CC
  CE
  PASAPORTE
  NIT
}

enum LeaseStatus {
  BORRADOR
  ACTIVO
  VENCIDO
  TERMINADO
  RENOVADO
}

enum PaymentMethod {
  NEQUI
  BANCOLOMBIA
  DAVIVIENDA
  EFECTIVO
  TRANSFERENCIA
  OTRO
}

enum PaymentStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum UtilityType {
  AGUA
  LUZ
  GAS
}

enum UtilityBillStatus {
  PENDIENTE
  PAGADO
  VENCIDO
}

enum PqrsType {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
}

enum PqrsStatus {
  RADICADA
  EN_PROCESO
  RESUELTA
  CERRADA
}

enum AlertType {
  VENCIMIENTO_PAGO
  VENCIMIENTO_SERVICIO
  VENCIMIENTO_CONTRATO
  PQRS_SIN_RESPUESTA
  PAGO_RECHAZADO
}

enum AlertChannel {
  EMAIL
  WHATSAPP
  PUSH
  ALL
}

enum AlertStatus {
  PENDIENTE
  ENVIADA
  FALLIDA
}

// ============================================================
// MODELS
// ============================================================

model Tenant {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(255)
  slug          String       @unique @db.VarChar(100)
  logo          String?      @db.VarChar(500)
  plan          Plan         @default(FREE)
  status        TenantStatus @default(ACTIVE)
  configJson    Json?
  maxProperties Int          @default(5)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  users        User[]
  properties   Property[]
  leases       Lease[]
  payments     Payment[]
  utilityBills UtilityBill[]
  pqrs         PQRS[]
  alerts       Alert[]
  auditLogs    AuditLog[]
  documents    Document[]

  @@map("tenants")
}

model User {
  id                  Int        @id @default(autoincrement())
  tenantId            Int        @map("tenant_id")
  email               String     @unique @db.VarChar(255)
  passwordHash        String     @map("password_hash") @db.VarChar(255)
  firstName           String     @map("first_name") @db.VarChar(100)
  lastName            String     @map("last_name") @db.VarChar(100)
  role                UserRole   @default(ARRENDATARIO)
  status              UserStatus @default(ACTIVE)
  avatar              String?    @db.VarChar(500)
  phone               String?    @db.VarChar(20)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  lastLoginAt         DateTime?  @map("last_login_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantPerson TenantPerson?
  payments     Payment[]
  pqrs         PQRS[]
  auditLogs    AuditLog[]

  @@index([tenantId])
  @@map("users")
}

model Property {
  id          Int            @id @default(autoincrement())
  tenantId    Int            @map("tenant_id")
  name        String         @db.VarChar(255)
  type        PropertyType
  address     String         @db.VarChar(500)
  city        String         @db.VarChar(100)
  state       String         @db.VarChar(100)
  country     String         @default("Colombia") @db.VarChar(100)
  area        Decimal?       @db.Decimal(10, 2)
  bedrooms    Int?
  bathrooms   Int?
  description String?        @db.Text
  status      PropertyStatus @default(DISPONIBLE)
  photos      Json?
  monthlyRent Decimal        @map("monthly_rent") @db.Decimal(12, 2)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leases       Lease[]
  utilityBills UtilityBill[]
  pqrs         PQRS[]

  @@index([tenantId])
  @@map("properties")
}

model TenantPerson {
  id                    Int          @id @default(autoincrement())
  userId                Int          @unique @map("user_id")
  documentType          DocumentType @map("document_type")
  documentNumber        String       @map("document_number") @db.VarChar(50)
  phone                 String?      @db.VarChar(20)
  emergencyContactName  String?      @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String?      @map("emergency_contact_phone") @db.VarChar(20)
  notes                 String?      @db.Text
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leases Lease[]

  @@map("tenant_persons")
}

model Lease {
  id             Int         @id @default(autoincrement())
  tenantId       Int         @map("tenant_id")
  propertyId     Int         @map("property_id")
  tenantPersonId Int         @map("tenant_person_id")
  startDate      DateTime    @map("start_date") @db.Date
  endDate        DateTime    @map("end_date") @db.Date
  monthlyRent    Decimal     @map("monthly_rent") @db.Decimal(12, 2)
  deposit        Decimal     @db.Decimal(12, 2)
  terms          String?     @db.Text
  status         LeaseStatus @default(BORRADOR)
  zapsignDocId   String?     @map("zapsign_doc_id") @db.VarChar(255)
  zapsignStatus  String?     @map("zapsign_status") @db.VarChar(50)
  signedDocUrl   String?     @map("signed_doc_url") @db.VarChar(500)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenantPerson TenantPerson @relation(fields: [tenantPersonId], references: [id], onDelete: Restrict)
  payments     Payment[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([tenantPersonId])
  @@map("leases")
}

model Payment {
  id              Int           @id @default(autoincrement())
  tenantId        Int           @map("tenant_id")
  leaseId         Int           @map("lease_id")
  userId          Int           @map("user_id")
  amount          Decimal       @db.Decimal(12, 2)
  paymentDate     DateTime      @map("payment_date") @db.Date
  method          PaymentMethod
  reference       String?       @db.VarChar(255)
  supportUrl      String?       @map("support_url") @db.VarChar(500)
  notes           String?       @db.Text
  status          PaymentStatus @default(PENDIENTE)
  approvedBy      Int?          @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  rejectionReason String?       @map("rejection_reason") @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease   Lease           @relation(fields: [leaseId], references: [id], onDelete: Restrict)
  user    User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  receipt PaymentReceipt?

  @@index([tenantId])
  @@index([leaseId])
  @@index([userId])
  @@map("payments")
}

model PaymentReceipt {
  id           Int      @id @default(autoincrement())
  paymentId    Int      @unique @map("payment_id")
  pdfUrl       String   @map("pdf_url") @db.VarChar(500)
  sentEmail    Boolean  @default(false) @map("sent_email")
  sentWhatsapp Boolean  @default(false) @map("sent_whatsapp")
  createdAt    DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_receipts")
}

model UtilityBill {
  id         Int               @id @default(autoincrement())
  tenantId   Int               @map("tenant_id")
  propertyId Int               @map("property_id")
  type       UtilityType
  amount     Decimal           @db.Decimal(12, 2)
  period     String            @db.VarChar(7)
  dueDate    DateTime          @map("due_date") @db.Date
  receiptUrl String?           @map("receipt_url") @db.VarChar(500)
  status     UtilityBillStatus @default(PENDIENTE)
  paidDate   DateTime?         @map("paid_date") @db.Date
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([propertyId])
  @@map("utility_bills")
}

model PQRS {
  id          Int        @id @default(autoincrement())
  tenantId    Int        @map("tenant_id")
  userId      Int        @map("user_id")
  propertyId  Int        @map("property_id")
  type        PqrsType
  subject     String     @db.VarChar(255)
  description String     @db.Text
  attachments Json?
  status      PqrsStatus @default(RADICADA)
  assignedTo  Int?       @map("assigned_to")
  resolution  String?    @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([userId])
  @@index([propertyId])
  @@map("pqrs")
}

model Alert {
  id            Int          @id @default(autoincrement())
  tenantId      Int          @map("tenant_id")
  type          AlertType
  referenceId   Int          @map("reference_id")
  referenceType String       @map("reference_type") @db.VarChar(50)
  message       String       @db.Text
  channel       AlertChannel @default(ALL)
  status        AlertStatus  @default(PENDIENTE)
  scheduledAt   DateTime?    @map("scheduled_at")
  sentAt        DateTime?    @map("sent_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("alerts")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  userId    Int      @map("user_id")
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  Int      @map("entity_id")
  details   Json?
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([userId])
  @@map("audit_logs")
}

model Document {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @map("tenant_id")
  entity    String   @db.VarChar(100)
  entityId  Int      @map("entity_id")
  category  String   @db.VarChar(100)
  fileUrl   String   @map("file_url") @db.VarChar(500)
  fileName  String   @map("file_name") @db.VarChar(255)
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("documents")
}
